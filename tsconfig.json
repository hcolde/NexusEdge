{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": true,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": true,
    "useUnknownInCatchVariables": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "stripInternal": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules", "examples"]
}
